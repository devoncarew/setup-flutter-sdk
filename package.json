{
  "name": "setup-flutter-action",
  "version": "1.0.0",
  "description": "A GitHub action to install the Flutter SDK.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && ncc build lib/index.js -o dist --minify",
    "lint": "eslint src/",
    "test": "jest"
  },
  "dependencies": {
    "@actions/cache": "^6.0.0",
    "@actions/core": "^3.0.0",
    "@actions/http-client": "^4.0.0",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.5.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/src/**/*.test.ts"
    ]
  }
}
